# === Telegram ===
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ALLOWED_USER_IDS=123456789,987654321  # Comma-separated Telegram user IDs (security!)

# === Domain ===
BASE_DOMAIN=yourdomain.com
# e.g., projects get deployed to clientname.yourdomain.com

# === Cloudflare Tunnel ===
TUNNEL_UUID=your-tunnel-uuid
CLOUDFLARED_CONFIG_PATH=/etc/cloudflared/config.yml
# Path to cloudflared credentials file
CLOUDFLARED_CREDENTIALS=/home/youruser/.cloudflared/<TUNNEL_UUID>.json

# === Paths ===
PROJECTS_DIR=/opt/appfactory-bot/projects
TEMPLATES_DIR=/opt/appfactory-bot/templates

# === Claude Code ===
ANTHROPIC_API_KEY=sk-ant-xxxxx  # Or rely on existing claude code auth
CLAUDE_MODEL=claude-sonnet-4-20250514

# === Voice / Transcription ===
# Option 1: OpenAI Whisper API (fast, accurate, costs ~$0.006/min)
OPENAI_API_KEY=
# Option 2: Leave OPENAI_API_KEY empty and install local whisper:
#   pip install openai-whisper && apt install ffmpeg

# === Docker ===
PORT_RANGE_START=9000
PORT_RANGE_END=9100

# === Database (SQLite — keeps it simple) ===
DB_PATH=/opt/appfactory-bot/data/projects.db
